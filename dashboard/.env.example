# Dashboard client-side environment variables.
# Only VITE_* keys are exposed to the frontend bundle by Vite.

# Local API target:
VITE_API_BASE=http://localhost:3000
# Production API target example:
# VITE_API_BASE=https://your-api.up.railway.app

# Local/testing Discord app and guild placeholders:
VITE_GUILD_ID=000000000000000000
VITE_CLIENT_ID=000000000000000000
VITE_SINGLE_GUILD_ID=
