NODE_ENV=production
PORT=3000
TRUST_PROXY=1
LOG_FORMAT=json

TOKEN=YOUR_DISCORD_BOT_TOKEN
TARGET_GUILD_ID=YOUR_TARGET_GUILD_ID
STARTUP_VOICE_CHANNEL_ID=

CLIENT_ID=YOUR_DISCORD_OAUTH_CLIENT_ID
CLIENT_SECRET=YOUR_DISCORD_OAUTH_CLIENT_SECRET
REDIRECT_URI=https://YOUR-RAILWAY-DOMAIN/api/auth/callback
SESSION_SECRET=REPLACE_WITH_AT_LEAST_16_CHARS_RANDOM_SECRET

CORS_ORIGIN=https://YOUR_DASHBOARD_DOMAIN
FRONTEND_URL=https://YOUR_DASHBOARD_DOMAIN

# Use only one of these styles. DATABASE_URL is recommended on Railway.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
DB_SSL=1

# Fallback discrete fields if DATABASE_URL is not used.
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_POOL_SIZE=10

RATE_WINDOW_MS=10000
RATE_AUTH_MAX=40
RATE_API_MAX=120
RATE_MAX_KEYS=5000

CACHE_PRUNE_TICK=500
CACHE_MAX_KEYS=10000

ABUSE_THRESHOLD=50
UNAUTH_REPLY_COOLDOWN_MS=8000
UNAUTH_WINDOW_MS=60000
UNAUTH_MAX_ATTEMPTS=8
UNAUTH_BLOCK_MS=120000

METRICS_TOKEN=
