NODE_ENV=production
PORT=3000
TRUST_PROXY=1
LOG_FORMAT=json

TOKEN=YOUR_DISCORD_BOT_TOKEN
TARGET_GUILD_ID=YOUR_TARGET_GUILD_ID
STARTUP_VOICE_CHANNEL_ID=
ENABLE_CONTROL_PLANE_API=0
ENABLE_CONTROL_PLANE_AUTH=0

CLIENT_ID=YOUR_DISCORD_OAUTH_CLIENT_ID
CLIENT_SECRET=YOUR_DISCORD_OAUTH_CLIENT_SECRET
REDIRECT_URI=https://your-api.up.railway.app/api/auth/callback
SESSION_SECRET=REPLACE_WITH_AT_LEAST_16_CHARS_RANDOM_SECRET
CONTROL_PLANE_SESSION_COOKIE_NAME=cp_session
CONTROL_PLANE_SESSION_TTL_MS=28800000
CONTROL_PLANE_OAUTH_STATE_TTL_MS=600000
CONTROL_PLANE_AUTH_COOKIE_SECURE=1
CONTROL_PLANE_AUTH_COOKIE_SAMESITE=Lax
CONTROL_PLANE_AUTH_POST_LOGIN_REDIRECT=https://your-dashboard.pages.dev/
# Browser origin allowed for credentialed dashboard calls and protected mutation origin checks.
# For local dev, if omitted, localhost:5173 and 127.0.0.1:5173 are allowed automatically.
CONTROL_PLANE_DASHBOARD_ALLOWED_ORIGIN=https://your-dashboard.pages.dev
# Public API base URL (external backend URL). Keep this aligned with Railway app URL.
CONTROL_PLANE_PUBLIC_BASE_URL=https://your-api.up.railway.app
CONTROL_PLANE_DEFAULT_PLAN=free
# Comma-separated guild override list: 123456789012345678:pro,234567890123456789:business
CONTROL_PLANE_PLAN_OVERRIDES=
ENABLE_CONTROL_PLANE_SHARED_STATE=0
CONTROL_PLANE_SHARED_STATE_PROVIDER=memory
CONTROL_PLANE_SHARED_STATE_REDIS_URL=
CONTROL_PLANE_SHARED_STATE_REDIS_PREFIX=cp:ss
CONTROL_PLANE_SHARED_STATE_REDIS_CONNECT_TIMEOUT_MS=1500
CONTROL_PLANE_SHARED_STATE_REDIS_FALLBACK_TO_MEMORY=1
ENABLE_CONTROL_PLANE_SCHEDULER=0
CONTROL_PLANE_SCHEDULER_PROVIDER=memory
CONTROL_PLANE_SCHEDULER_FALLBACK_TO_MEMORY=1
CONTROL_PLANE_SCHEDULER_REDIS_URL=
CONTROL_PLANE_SCHEDULER_REDIS_PREFIX=cp:scheduler
CONTROL_PLANE_SCHEDULER_REDIS_CONNECT_TIMEOUT_MS=1500
CONTROL_PLANE_SCHEDULER_REDIS_FALLBACK_TO_MEMORY=1
CONTROL_PLANE_SCHEDULER_HARDENED_DEFAULT_RECORD_TTL_MS=86400000
CONTROL_PLANE_AUTH_EXPIRY_CLEANUP_SCHEDULER_ENABLED=0

# Compatibility fallbacks (use CONTROL_PLANE_DASHBOARD_ALLOWED_ORIGIN instead for new setups).
CORS_ORIGIN=https://your-dashboard.pages.dev
FRONTEND_URL=https://your-dashboard.pages.dev

# Use only one of these styles. DATABASE_URL is recommended on Railway.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
DB_SSL=1

# Fallback discrete fields if DATABASE_URL is not used.
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_POOL_SIZE=10

RATE_WINDOW_MS=10000
RATE_AUTH_MAX=40
RATE_API_MAX=120
RATE_MAX_KEYS=5000

CACHE_PRUNE_TICK=500
CACHE_MAX_KEYS=10000

ABUSE_THRESHOLD=50
UNAUTH_REPLY_COOLDOWN_MS=8000
UNAUTH_WINDOW_MS=60000
UNAUTH_MAX_ATTEMPTS=8
UNAUTH_BLOCK_MS=120000

METRICS_TOKEN=
